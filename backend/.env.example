DATABASE_URL=sqlite:///./foodloop.db
# PostgreSQL example:
# DATABASE_URL=postgresql+psycopg://postgres:YOUR_PASSWORD@localhost:5432/foodloop_ai
FRONTEND_URL=http://localhost:5173
UPLOAD_DIR=app/uploads
FOOD_JSON_PATH=app/data/traditional_indonesian_foods.json

# Use rules/mock without an API key. Use openai when OPENAI_API_KEY is set.
TEXT_ANALYZER_MODE=rules
LEFTOVER_IDENTIFIER_MODE=mock
RECIPE_RESPONSE_MODE=rules
OPENAI_API_KEY=
OPENAI_TEXT_MODEL=gpt-5.5
OPENAI_VISION_MODEL=gpt-5.5

# Google OAuth placeholders. Frontend currently uses demo Google login.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://127.0.0.1:8000/api/auth/google/callback

# Comma-separated developer emails allowed to open /admin.
ADMIN_EMAILS=

# Optional email reminder sending. If empty, reminders are logged but not sent.
REMINDER_EMAIL_FROM=FoodLoop AI <no-reply@foodloop.ai>
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true

# WhatsApp is prepared for template/provider integration later.
WHATSAPP_PROVIDER_MODE=disabled

# Telegram bot access. Create the bot in Telegram with @BotFather.
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=

# WhatsApp Cloud API / Meta Business Platform.
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_BOT_NUMBER=

# Public Render/backend URL used for webhooks and PDF links.
PUBLIC_BACKEND_URL=https://your-backend-url.onrender.com
